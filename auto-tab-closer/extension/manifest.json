{
  "manifest_version": 3,
  "name": "Auto Tab Closer",
  "version": "1.0.0",
  "description": "Automatically closes logged-out tabs (AWS, Google, GitHub, etc.) after idle time",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "action"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Auto Tab Closer"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
